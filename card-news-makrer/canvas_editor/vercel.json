{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",

  "installCommand": "npm install --legacy-peer-deps",

  "framework": "nextjs",

  "regions": [
    "icn1"
  ],

  "redirects": [
    {
      "source": "/editor",
      "destination": "/",
      "permanent": false
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],

  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
